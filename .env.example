# ============================================================
# RemunaIA — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores reais
# NUNCA commite o .env.local no GitHub
# ============================================================

# --- SUPABASE (copiar de: supabase.com → projeto → Settings → API) ---
VITE_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=SEU_ANON_KEY_PUBLICO

# --- STRIPE (copiar de: dashboard.stripe.com → Payment Links) ---
VITE_STRIPE_STARTER_LINK=https://buy.stripe.com/LINK_STARTER
VITE_STRIPE_PROFESSIONAL_LINK=https://buy.stripe.com/LINK_PROFESSIONAL
VITE_STRIPE_ENTERPRISE_LINK=https://buy.stripe.com/LINK_ENTERPRISE

# --- POSTHOG (copiar de: posthog.com → projeto → API key) ---
VITE_POSTHOG_KEY=phc_SUA_CHAVE_POSTHOG

# --- URL DO APP ---
VITE_APP_URL=http://localhost:5173

# ============================================================
# As chaves abaixo ficam APENAS no Supabase (secrets das Edge Functions)
# NÃO adicione aqui — configurar via: supabase secrets set CHAVE=valor
# ============================================================
# GEMINI_API_KEY=AIzaSy...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# RESEND_API_KEY=re_...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
