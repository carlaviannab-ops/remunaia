# ============================================================
# RemunaIA — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores reais
# NUNCA commite o .env.local no GitHub
# ============================================================

# --- SUPABASE (copiar de: supabase.com → projeto → Settings → API) ---
VITE_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=SEU_ANON_KEY_PUBLICO

# --- PIX (sua chave PIX para receber pagamentos) ---
VITE_PIX_KEY=seu@email.com

# --- WHATSAPP (número completo com DDI+DDD, só números) ---
VITE_WHATSAPP=5511999999999

# --- ADMIN (e-mail do usuário com acesso ao painel /admin) ---
VITE_ADMIN_EMAIL=seu@email.com

# --- POSTHOG (opcional — analytics) ---
VITE_POSTHOG_KEY=phc_SUA_CHAVE_POSTHOG

# --- URL DO APP ---
VITE_APP_URL=http://localhost:5173

# ============================================================
# As chaves abaixo ficam APENAS no Supabase Edge Functions → Secrets
# NÃO adicione aqui
# ============================================================
# GEMINI_API_KEY=AIzaSy...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
